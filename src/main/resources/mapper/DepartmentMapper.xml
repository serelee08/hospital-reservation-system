<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hospital.reservation.dao.DepartmentDAO">

    <select id="findAll" resultType="com.hospital.reservation.vo.DepartmentVO">
        SELECT * FROM department ORDER BY department_no
    </select>

    <select id="findById" resultType="com.hospital.reservation.vo.DepartmentVO">
        SELECT * FROM department WHERE department_no = #{departmentNo}
    </select>

    <insert id="insert" parameterType="com.hospital.reservation.vo.DepartmentVO">
        INSERT INTO department (department_name, description)
        VALUES (#{departmentName}, #{description})
    </insert>

    <update id="update" parameterType="com.hospital.reservation.vo.DepartmentVO">
        UPDATE department
        SET department_name = #{departmentName},
            description     = #{description}
        WHERE department_no = #{departmentNo}
    </update>

    <delete id="delete">
        DELETE FROM department WHERE department_no = #{departmentNo}
    </delete>

</mapper>